{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generalist-bt-gen.local/evaluation/core-missions.schema.json",
  "title": "Core thesis evaluation missions",
  "type": "object",
  "required": ["dataset_version", "freeze_status", "source_snapshot", "missions"],
  "properties": {
    "dataset_version": {"type": "string"},
    "freeze_status": {"enum": ["draft", "frozen"]},
    "source_snapshot": {
      "type": "object",
      "required": ["repository_commit", "tree_metadata_sha256", "system_description_sha256"]
    },
    "missions": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {"$ref": "#/$defs/mission"}
    }
  },
  "$defs": {
    "mission": {
      "type": "object",
      "required": [
        "id", "title", "platform", "support_status", "complexity",
        "paraphrases", "context_fixture", "requirements", "expected",
        "reference_behavior", "semantic_rubric_elements"
      ],
      "properties": {
        "id": {"pattern": "^[SMC][1-3]$"},
        "title": {"type": "string", "minLength": 3},
        "platform": {"enum": ["husky", "blueboat"]},
        "support_status": {"enum": ["implemented_catalogue", "blocked_blueboat_implementation"]},
        "complexity": {
          "type": "object",
          "required": ["label", "scores", "total"],
          "properties": {
            "label": {"enum": ["simple", "medium", "complex"]},
            "scores": {
              "type": "object",
              "required": ["mission_phases", "action_types", "context_sources", "constraints", "control_flow", "spatial_reasoning"],
              "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 2}
            },
            "total": {"type": "integer", "minimum": 0, "maximum": 12}
          }
        },
        "paraphrases": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": {"type": "string"},
              "text": {"type": "string", "minLength": 10}
            }
          }
        },
        "context_fixture": {"type": "string"},
        "requirements": {"type": "object"},
        "expected": {
          "type": "object",
          "required": ["outcome", "tree_id", "canonical_payload"],
          "properties": {"outcome": {"const": "plan"}}
        },
        "reference_behavior": {"type": "array", "minItems": 1},
        "semantic_rubric_elements": {"type": "array", "minItems": 3}
      }
    }
  }
}
