<?xml version="1.0"?>
<!--
Tree Name: explore_area.xml
Description: Execute a static exploration route generated from an operator-defined
             area. The LLM/context pipeline chooses frontier or coverage waypoints
             before execution; this tree only validates that at least one waypoint
             exists and drives the ordered route with Nav2.
Usage Instructions:
  - Payload must include "waypoints" as semicolon-separated x,y,yaw entries in
    the map frame.
  - Payload should also include "area_polygon" and "frontiers" for review and
    UI visualization; those fields are not consumed by this tree.
-->
<root BTCPP_format="4" main_tree_to_execute="explore_area.xml">
  <BehaviorTree ID="explore_area.xml">
    <Sequence name="ExploreAreaMission">
      <ParseWaypoints raw_waypoints="{waypoints}" waypoint_queue="{waypoint_queue}" waypoint_count="{waypoint_count}" />
      <Precondition if="waypoint_count > 0" else="FAILURE">
        <LoopString queue="{waypoint_queue}" value="{active_waypoint}" if_empty="FAILURE">
          <Sequence name="VisitExplorationWaypoint">
            <MoveTo name="DriveToExplorationWaypoint" pose="{active_waypoint}" action_name="/a200_0000/navigate_to_pose"/>
          </Sequence>
        </LoopString>
      </Precondition>
    </Sequence>
  </BehaviorTree>
</root>
